# Required — Reddit + TikTok + Instagram via ScrapeCreators
SCRAPECREATORS_API_KEY=

# Optional — X / Twitter via cookie auth (default path; rotates ~weekly)
# Get from a logged-in x.com browser → DevTools → Application → Cookies
AUTH_TOKEN=
CT0=

# Optional — native web search (free 2,000 queries/month)
BRAVE_API_KEY=

# Optional — Bluesky as a source
# Create app password at bsky.app/settings/app-passwords
BSKY_HANDLE=
BSKY_APP_PASSWORD=

# Optional — only if your synthesis path calls Claude directly
# Hermes does NOT need this; it uses its own model.
ANTHROPIC_API_KEY=

# GitHub auth — set ONE of:
#  (a) SSH key for ~/.ssh/id_ed25519 + gh auth login (recommended)
#  (b) GITHUB_TOKEN here (fine-grained PAT with repo:write on this repo)
GITHUB_TOKEN=

# Repo target (override only if forking)
REPO_SLUG=
REPO_BRANCH=main
